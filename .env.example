# appif - Environment Variables
# Copy this file to ~/.env and fill in your values:
#   cp .env.example ~/.env
#
# NEVER commit actual credentials. This file documents expected keys only.

# --- Gmail ---
# OAuth client credentials (required for consent script and as fallback).
# See docs/design/gmail/setup.md for full setup instructions.
# Step 1: Create OAuth client at https://console.cloud.google.com/apis/credentials
#          Type: Desktop application
APPIF_GMAIL_CLIENT_ID=
APPIF_GMAIL_CLIENT_SECRET=
# Step 2: Run consent flow: python scripts/gmail_consent.py <account-name>
# Step 3: Set the account email the connector should use
APPIF_GMAIL_ACCOUNT=
# Optional: directory for credential JSON files (default: ~/.config/appif/gmail)
# APPIF_GMAIL_CREDENTIALS_DIR=~/.config/appif/gmail
# Optional: polling interval in seconds (default: 30)
# APPIF_GMAIL_POLL_INTERVAL_SECONDS=30
# Optional: comma-separated label IDs to watch (default: INBOX)
# APPIF_GMAIL_LABEL_FILTER=INBOX
# Optional: AUTOMATIC (send immediately) or ASSISTED (create draft) (default: AUTOMATIC)
# APPIF_GMAIL_DELIVERY_MODE=AUTOMATIC

# --- Outlook / Microsoft 365 ---
# Azure AD app registration credentials.
# See docs/design/outlook/setup.md for full setup instructions.
# Step 1: Register an app at https://portal.azure.com -> App registrations
# Step 2: Run consent flow: python scripts/outlook_consent.py <account-name>
APPIF_OUTLOOK_CLIENT_ID=
# Optional: only needed for confidential-client flow (server-side apps)
# APPIF_OUTLOOK_CLIENT_SECRET=
# Optional: Azure AD tenant; "common" allows personal + org accounts (default: common)
# APPIF_OUTLOOK_TENANT_ID=common
# Optional: logical account label mapping to credential file (default: default)
# APPIF_OUTLOOK_ACCOUNT=default
# Optional: directory for per-account token caches (default: ~/.config/appif/outlook)
# APPIF_OUTLOOK_CREDENTIALS_DIR=~/.config/appif/outlook
# Optional: delta-poll cadence in seconds (default: 30)
# APPIF_OUTLOOK_POLL_INTERVAL_SECONDS=30
# Optional: comma-separated well-known folder names (default: Inbox)
# APPIF_OUTLOOK_FOLDER_FILTER=Inbox
# Optional: poll for v1; future: subscription (default: poll)
# APPIF_OUTLOOK_DELIVERY_MODE=poll

# --- Slack (messaging connector) ---
# Create a Slack app at https://api.slack.com/apps with Socket Mode enabled.
# See docs/design/slack/setup.md for step-by-step instructions.
# Required scopes: channels:history, channels:read, groups:history, groups:read,
#   im:history, im:read, mpim:history, mpim:read, chat:write, users:read, connections:write
APPIF_SLACK_BOT_OAUTH_TOKEN=
APPIF_SLACK_BOT_APP_LEVEL_TOKEN=
# User OAuth token — sees everything you can see (for reading as yourself)
APPIF_SLACK_USER_OAUTH_TOKEN=
# APPIF_SLACK_BOT_SIGNING_SECRET=
# APPIF_SLACK_BOT_CLIENT_ID=
# APPIF_SLACK_BOT_CLIENT_SECRET=
# APPIF_SLACK_BOT_APP_ID=

# --- Jira (work tracking) ---
# Configuration is YAML-based, not env vars. Create config at:
#   ~/.config/appif/jira/config.yaml
# Or override the path:
# APPIF_JIRA_CONFIG=~/.config/appif/jira/config.yaml
#
# Config format:
#   instances:
#     personal:
#       jira:
#         url: https://your-domain.atlassian.net
#         username: your-email@example.com
#         api_token: your-api-token
#   default: personal

# --- Claude / Anthropic (for email evaluation script) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Prompt files (optional, for customising script behaviour) ---
# Override the default prompt file path (~/.config/appif/prompts/email_evaluator.txt)
# APPIF_EMAIL_EVAL_PROMPT=~/.config/appif/prompts/email_evaluator.txt
